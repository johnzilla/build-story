{
  "name": "build-story",
  "private": true,
  "scripts": {
    "build": "pnpm --filter '@buildstory/core' build",
    "test": "pnpm --filter '*' test",
    "lint": "eslint packages/*/src",
    "format": "prettier --write .",
    "clean": "pnpm --filter '*' exec -- rm -rf dist"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "eslint": "^10.2.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
